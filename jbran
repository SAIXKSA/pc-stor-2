function updateBuilderSummary() {
  const breakdown = document.getElementById('builderPriceBreakdown');
  const totalEl   = document.getElementById('builderTotal');
  const compatEl  = document.getElementById('compatCheck');
  if (!breakdown || !totalEl) return;

  let total = 0;
  let rows  = '';
  builderSlotDefs.forEach(slot => {
    const item = state.builder[slot.key];
    if (item) {
      total += item.price;
      rows += `<div class="summary-row"><span>${slot.label}</span><span>${item.price.toLocaleString()} ر</span></div>`;
    }
  });
  breakdown.innerHTML = rows;
  totalEl.textContent = total.toLocaleString() + ' ريال';

  // Compatibility status panel
  if (compatEl) {
    const cpu = state.builder.cpu;
    const mb  = state.builder.mb;
    const ram = state.builder.ram;
    let compatRows = '';
    if (!cpu && !mb) {
      compatRows = `<div class="compat-row"><div class="dot-gray"></div><span style="color:var(--muted)">اختر معالجاً ولوحة أم لفحص التوافق</span></div>`;
    } else {
      const issues = checkCompatibility();
      if (!issues.length) {
        compatRows = `<div class="compat-row"><div class="dot-gray"></div><span style="color:var(--muted)">أضف المزيد من القطع لفحص التوافق</span></div>`;
      } else {
        compatRows = issues.map(i => {
          const dot = i.type==='ok' ? 'dot-green' : i.type==='warn' ? 'dot-orange' : 'dot-orange';
          const color = i.type==='ok' ? 'var(--green)' : 'var(--accent3)';
          if (i.type==='error') {
            return `<div class="compat-row"><div style="width:8px;height:8px;border-radius:50%;background:var(--red);flex-shrink:0;"></div><span style="color:var(--red);font-size:12px;">${i.msg}</span></div>`;
          }
          return `<div class="compat-row"><div class="${dot}"></div><span style="color:${color};font-size:12px;">${i.msg}</span></div>`;
        }).join('');
      }
    }
    compatEl.innerHTML = `<div style="font-size:12px;font-weight:600;color:var(--muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">حالة التوافق</div>${compatRows}`;
  }
}

