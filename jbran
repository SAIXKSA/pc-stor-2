// مساعدات عرض الأخطاء
function setFieldError(inputId, errId, msg) {
  const input = document.getElementById(inputId);
  const err   = document.getElementById(errId);
  if (input) { input.classList.add('input-error'); input.classList.remove('input-ok'); }
  if (err)   { err.textContent = msg; }
}
function setFieldOk(inputId) {
  const input = document.getElementById(inputId);
  if (input) { input.classList.remove('input-error'); input.classList.add('input-ok'); }
}
function clearFieldError(inputId, errId) {
  const input = document.getElementById(inputId);
  const err   = document.getElementById(errId);
  if (input) { input.classList.remove('input-error'); input.classList.remove('input-ok'); }
  if (err)   { err.textContent = ''; }
}
function clearAllLoginErrors() {
  ['loginEmail','loginPass'].forEach(id => { const el=document.getElementById(id); if(el){el.classList.remove('input-error','input-ok');} });
  ['loginEmailErr','loginPassErr'].forEach(id => { const el=document.getElementById(id); if(el) el.textContent=''; });
}

function togglePassVis(inputId, btn) {
  const input = document.getElementById(inputId);
  if (!input) return;
  if (input.type === 'password') { input.type = 'text'; btn.textContent = '🙈'; }
  else { input.type = 'password'; btn.textContent = '👁'; }
}

function checkPassStrength(val) {
  const bar = document.getElementById('passStrengthBar');
  const lbl = document.getElementById('passStrengthLabel');
  const wrap = document.getElementById('passStrength');
  if (!bar || !lbl || !wrap) return;
  if (!val) { wrap.style.display='none'; return; }
  wrap.style.display = 'block';
  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const levels = [
    {w:'25%', c:'var(--red)',    l:'ضعيفة جداً'},
    {w:'50%', c:'var(--accent3)',l:'ضعيفة'},
    {w:'75%', c:'var(--accent3)',l:'متوسطة'},
    {w:'100%',c:'var(--green)',  l:'قوية ✓'},
  ];
  const lv = levels[Math.max(0,score-1)] || levels[0];
  bar.style.width = lv.w; bar.style.background = lv.c;
  lbl.style.color = lv.c; lbl.textContent = 'قوة كلمة المرور: ' + lv.l;
}

function doLogin() {
  clearAllLoginErrors();
  const email = document.getElementById('loginEmail').value.trim();
  const pass  = document.getElementById('loginPass').value;
  const lockEl = document.getElementById('loginLockMsg');
  const attEl  = document.getElementById('loginAttempts');
  const btn    = document.getElementById('loginBtn');

  // فحص القفل
  const att = getAttempts();
  if (att.lockedUntil > Date.now()) {
    const secsLeft = Math.ceil((att.lockedUntil - Date.now()) / 1000);
    lockEl.style.display = 'block';
    lockEl.innerHTML = `🔒 تم تعطيل حسابك مؤقتاً بسبب محاولات كثيرة<br><span style="font-size:12px;">يمكنك المحاولة مجدداً بعد <strong>${secsLeft}</strong> ثانية</span>`;
    // عداد تنازلي
    if (!btn._lockTimer) {
      btn._lockTimer = setInterval(() => {
        const s = Math.ceil((att.lockedUntil - Date.now()) / 1000);
        if (s <= 0) {
          clearInterval(btn._lockTimer); btn._lockTimer = null;
          lockEl.style.display='none'; attEl.style.display='none';
          btn.disabled=false; btn.textContent='تسجيل الدخول'; btn.style.opacity='1';
          resetAttempts();
        } else {
          lockEl.innerHTML=`🔒 تم تعطيل حسابك مؤقتاً بسبب محاولات كثيرة<br><span style="font-size:12px;">يمكنك المحاولة مجدداً بعد <strong>${s}</strong> ثانية</span>`;
        }
      }, 1000);
    }
    btn.disabled=true; btn.style.opacity='.5';
    return;
  }

  // التحقق من الحقول الفارغة
  let hasError = false;
  if (!email) { setFieldError('loginEmail','loginEmailErr','⚠ يرجى إدخال البريد الإلكتروني'); hasError=true; }
  else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setFieldError('loginEmail','loginEmailErr','⚠ صيغة البريد الإلكتروني غير صحيحة'); hasError=true; }
  if (!pass)  { setFieldError('loginPass','loginPassErr','⚠ يرجى إدخال كلمة المرور'); hasError=true; }
  if (hasError) return;

  // تأخير بسيط للمحاكاة
  btn.disabled=true; btn.textContent='جارٍ التحقق...'; btn.style.opacity='.7';
  setTimeout(() => {
    btn.disabled=false; btn.textContent='تسجيل الدخول'; btn.style.opacity='1';

    const users = getUsers();
    const userByEmail = users.find(u => u.email.toLowerCase() === email.toLowerCase());

    if (!userByEmail) {
      // البريد غير موجود
      setFieldError('loginEmail','loginEmailErr','⚠ لا يوجد حساب مرتبط بهذا البريد الإلكتروني');
      document.getElementById('loginEmail').focus();
      shakeInput('loginEmail');
      return;
    }

    if (userByEmail.pass !== pass) {
      // كلمة المرور خاطئة
      setFieldError('loginPass','loginPassErr','⚠ كلمة المرور غير صحيحة');
      document.getElementById('loginPass').value = '';
      document.getElementById('loginPass').focus();
      shakeInput('loginPass');

      // تسجيل المحاولة الفاشلة
      att.count = (att.count||0) + 1;
      const remaining = 5 - att.count;
      if (att.count >= 5) {
        att.lockedUntil = Date.now() + 60000; // قفل دقيقة
        saveAttempts(att);
        lockEl.style.display='block';
        lockEl.innerHTML='🔒 تم تعطيل حسابك مؤقتاً — حاول مجدداً بعد 60 ثانية';
        attEl.style.display='none';
        doLogin(); // لتشغيل العداد
      } else {
        saveAttempts(att);
        if (remaining <= 3) {
          attEl.style.display='block';
          attEl.textContent = `⚠ تبقى ${remaining} محاولة قبل القفل المؤقت`;
        }
      }
      return;
    }

    // نجاح تسجيل الدخول
    resetAttempts();
    lockEl.style.display='none'; attEl.style.display='none';
    setFieldOk('loginEmail'); setFieldOk('loginPass');
    state.user = { email: userByEmail.email, fname: userByEmail.fname, lname: userByEmail.lname||'', name: `${userByEmail.fname} ${userByEmail.lname||''}`.trim(), phone: userByEmail.phone||'' };
    document.getElementById('userBtn').textContent = '👤✓';
    showToast(`✅ مرحباً ${userByEmail.fname}! تم تسجيل دخولك بنجاح`, 'success');
    setTimeout(() => showPage('home'), 400);
  }, 800);
}

function doRegister() {
  const fname  = document.getElementById('regFname').value.trim();
  const lname  = document.getElementById('regLname').value.trim();
  const email  = document.getElementById('regEmail').value.trim();
  const pass   = document.getElementById('regPass').value;
  const pass2  = document.getElementById('regPass2').value;

  let hasError = false;
  if (!fname) { setFieldError('regFname','regFnameErr','⚠ الاسم الأول مطلوب'); hasError=true; }
  if (!email) { setFieldError('regEmail','regEmailErr','⚠ البريد الإلكتروني مطلوب'); hasError=true; }
  else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setFieldError('regEmail','regEmailErr','⚠ صيغة البريد الإلكتروني غير صحيحة'); hasError=true; }
  if (!pass) { setFieldError('regPass','regPassErr','⚠ كلمة المرور مطلوبة'); hasError=true; }
  else if (pass.length < 6) { setFieldError('regPass','regPassErr','⚠ كلمة المرور يجب أن تكون 6 أحرف على الأقل'); hasError=true; }
  if (pass !== pass2) { setFieldError('regPass2','regPass2Err','⚠ كلمتا المرور غير متطابقتين'); hasError=true; }
  if (hasError) return;

  const users = getUsers();
  if (users.find(u => u.email.toLowerCase() === email.toLowerCase())) {
    setFieldError('regEmail','regEmailErr','⚠ هذا البريد الإلكتروني مسجّل مسبقاً');
    shakeInput('regEmail');
    return;
  }

  // إنشاء الحساب
  users.push({ email, pass, fname, lname, phone: document.getElementById('regPhone').value||'', joined: new Date().toISOString().slice(0,10) });
  saveUsers(users);
  state.user = { email, fname, lname, name:`${fname} ${lname}`.trim() };
  document.getElementById('userBtn').textContent = '👤✓';
  showToast(`🎉 مرحباً ${fname}! تم إنشاء حسابك بنجاح`, 'success');
  setTimeout(() => showPage('home'), 400);
}

function shakeInput(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.animation = 'none';
  el.offsetHeight; // reflow
  el.style.animation = 'shake .4s ease';
}

function socialLogin(provider) {
  state.user = {email:`user@${provider.toLowerCase()}.com`, fname: 'مستخدم', lname:'', name:'مستخدم'};
  document.getElementById('userBtn').textContent = '👤✓';
  showToast(`✅ تم الدخول بـ ${provider}`, 'success');
  showPage('home');
}

function doLogout() {
  state.user = null;
  document.getElementById('userBtn').textContent = '👤';
  showToast('تم تسجيل الخروج', 'success');
  showPage('home');
}

