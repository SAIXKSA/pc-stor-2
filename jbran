// CONTACT
// ============================
function sendContact() {
  const name = document.getElementById('ctName').value;
  const msg = document.getElementById('ctMsg').value;
  if (!name || !msg) { showToast('❌ يرجى تعبئة الحقول المطلوبة', 'error'); return; }
  showToast('📨 تم إرسال رسالتك بنجاح، سنتواصل معك قريباً', 'success');
  ['ctName','ctEmail','ctSubject','ctMsg'].forEach(id => { const el = document.getElementById(id); if(el) el.value=''; });
}

