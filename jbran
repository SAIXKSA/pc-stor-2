  const code = document.getElementById('couponInput').value.toUpperCase();
  if (code === 'SAVE10') { discount = Math.round(state.cart.reduce((s,i)=>s+i.price*i.qty,0)*0.1); showToast('🎉 تم تطبيق كود الخصم 10%', 'success'); }
  else if (code === 'PCSTORE') { discount = 200; showToast('🎉 تم خصم 200 ريال', 'success'); }
  else { showToast('❌ كود الخصم غير صحيح', 'error'); return; }
  updateCartSummary();
}

