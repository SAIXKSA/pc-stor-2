function addToCart(id) {
  const p = products.find(x=>x.id===id);
  if (!p) return;
  const existing = state.cart.find(x=>x.id===id);
  if (existing) { existing.qty++; }
  else { state.cart.push({...p, qty:1}); }
  updateCartBadge();
  showToast(`✅ تم إضافة ${p.name} للسلة`, 'success');
}

function updateCartBadge() {
  const total = state.cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('cartBadge').textContent = total;
}

function renderCart() {
  const el = document.getElementById('cartItems');
  if (!el) return;
  if (!state.cart.length) {
    el.innerHTML = '<div class="empty-state"><div class="icon">🛒</div><h3>السلة فارغة</h3><p>أضف بعض المنتجات للبدء</p><button class="btn btn-primary" style="margin-top:16px;" onclick="showPage(\'shop\')">تسوق الآن</button></div>';
  } else {
    el.innerHTML = state.cart.map(item => `
      <div class="cart-item">
        <div class="cart-item-img">${item.image ? `<img src="${item.image}" style="width:100%;height:100%;object-fit:contain;border-radius:8px;padding:4px;">` : item.icon}</div>
        <div class="cart-item-info">
          <div class="cart-item-name">${item.name}</div>
          <div class="cart-item-brand">${item.brand}</div>
        </div>
        <div class="qty-control">
          <button class="qty-btn" onclick="changeQty(${item.id},-1)">−</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${item.id},1)">+</button>
        </div>
        <div>
          <div class="cart-item-price">${(item.price*item.qty).toLocaleString()} ريال</div>
          <button onclick="removeFromCart(${item.id})" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:12px;margin-top:4px;">🗑 حذف</button>
        </div>
      </div>
    `).join('');
  }
  updateCartSummary();
}

function changeQty(id, delta) {
  const item = state.cart.find(x=>x.id===id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) state.cart = state.cart.filter(x=>x.id!==id);
  updateCartBadge();
  renderCart();
}
function removeFromCart(id) {
  state.cart = state.cart.filter(x=>x.id!==id);
  updateCartBadge();
  renderCart();
  showToast('🗑 تم حذف المنتج من السلة', 'error');
}

let discount = 0;
function updateCartSummary() {
  const sub = state.cart.reduce((s,i)=>s+i.price*i.qty,0);
  const total = Math.max(0, sub - discount);
  document.getElementById('subtotalDisplay').textContent = sub.toLocaleString() + ' ريال';
  document.getElementById('discountDisplay').textContent = '-' + discount.toLocaleString() + ' ريال';
  document.getElementById('totalDisplay').textContent = total.toLocaleString() + ' ريال';
}

