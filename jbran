function checkCompatibility() {
  const cpu = state.builder.cpu;
  const mb  = state.builder.mb;
  const ram = state.builder.ram;
  const issues = [];
  // CPU ↔ Motherboard socket
  if (cpu && mb) {
    if (cpu.socket !== mb.socket) {
      issues.push({type:'error', msg:`⚠️ المعالج (${cpu.socket}) لا يتوافق مع اللوحة الأم (${mb.socket})`});
    } else {
      issues.push({type:'ok', msg:`✅ المعالج واللوحة الأم متوافقان (${cpu.socket})`});
    }
  }
  // RAM ↔ Motherboard ramType
  if (ram && mb) {
    const mbSupports = mb.ramType || '';
    const ramType    = ram.ramType || '';
    if (!mbSupports.includes(ramType)) {
      issues.push({type:'error', msg:`⚠️ الرامات (${ramType}) لا تتوافق مع اللوحة الأم (تدعم: ${mbSupports})`});
    } else {
      issues.push({type:'ok', msg:`✅ الرامات واللوحة الأم متوافقتان (${ramType})`});
    }
  }
  // RAM ↔ CPU ramType
  if (ram && cpu && !mb) {
    const cpuSupports = cpu.ramType || '';
    const ramType     = ram.ramType || '';
    if (!cpuSupports.includes(ramType)) {
      issues.push({type:'warn', msg:`⚠️ تأكد أن الرامات (${ramType}) تتوافق مع المعالج`});
    }
  }
  return issues;
}

function selectBuilderComponent(slotKey, productId) {
