// normalize product from Supabase snake_case → camelCase
function normP(p) {
  return {
    id: p.id, name: p.name, brand: p.brand, category: p.category,
    price: Number(p.price), oldPrice: p.old_price ? Number(p.old_price) : null,
    stock: p.stock || 0, rating: Number(p.rating) || 4.5, reviews: p.reviews || 0,
    icon: p.icon || '📦', desc: p.description || '',
    specs: p.specs || {}, badge: p.badge || undefined,
    featured: p.featured || false, socket: p.socket || undefined,
    ramType: p.ram_type || undefined, image: p.image || undefined,
    subImages: p.sub_images || undefined
  };
}
function normO(o) {
  return { id: o.id, date: o.date, items: o.items, total: Number(o.total), status: o.status, customer: o.customer };
}

// ── DB: Supabase ──
const DB = {
  _products: DEFAULT_PRODUCTS,
  _orders: [],

  async init() {
    try {
      const [prods, orders] = await Promise.all([
        sbFetch('/rest/v1/products?order=id.asc'),
        sbFetch('/rest/v1/orders?order=created_at.desc')
      ]);
      this._products = prods.map(normP);
      this._orders   = orders.map(normO);
    } catch(e) {
      console.warn('Supabase init failed, using defaults:', e.message);
      this._products = DEFAULT_PRODUCTS;
    }
  },

  getProducts() { return this._products; },
  getOrders()   { return this._orders; },

  async saveOrder(order) {
    try {
      await sbFetch('/rest/v1/orders', {
        method: 'POST',
        body: JSON.stringify({
          id: order.id, date: order.date, items: order.items,
          total: order.total, status: order.status, customer: order.customer
        })
      });
      this._orders.unshift(order);
    } catch(e) {
      console.error('saveOrder error:', e.message);
    }
  },

  async refreshProducts() {
    try {
      const prods = await sbFetch('/rest/v1/products?order=id.asc');
      this._products = prods.map(normP);
    } catch(e) { console.warn('refresh error:', e); }
  }
};

