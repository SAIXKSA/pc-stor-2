  }
  .cat-btn:hover, .cat-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,212,255,0.07);
  }

  /* ===== SECTION ===== */
  .section { padding: 60px 40px; }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 30px;
  }
  .section-title {
    font-size: 24px;
    font-weight: 700;
  }
  .section-title span { color: var(--accent); }

  /* ===== PRODUCTS GRID ===== */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  .product-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: all .3s;
    cursor: pointer;
    position: relative;
  }
  .product-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4), var(--glow);
  }
  .product-badge-sale {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--red);
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    z-index: 1;
  }
  .product-badge-new {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--green);
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    z-index: 1;
  }
  .product-img {
    width: 100%;
    height: 180px;
    background: var(--bg3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    border-bottom: 1px solid var(--border);
    transition: all .3s;
  }
  .product-card:hover .product-img { background: var(--bg2); }
  .product-info { padding: 16px; }
  .product-brand { font-size: 11px; color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .product-name { font-size: 15px; font-weight: 600; margin-bottom: 8px; line-height: 1.4; }
  .product-specs { font-size: 12px; color: var(--muted); margin-bottom: 12px; line-height: 1.6; }
  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .product-price { font-size: 20px; font-weight: 900; color: var(--accent3); }
  .product-price-old { font-size: 13px; color: var(--muted); text-decoration: line-through; }
  .product-rating { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--muted); }
  .stars { color: var(--accent3); letter-spacing: -2px; }

  .btn-add-cart {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.3);
    color: var(--accent);
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
  }
  .btn-add-cart:hover { background: var(--accent); color: var(--bg); }

  /* ===== FILTER SIDEBAR ===== */
  .shop-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 24px;
    padding: 40px;
  }

  .sidebar {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    height: fit-content;
    position: sticky;
    top: 80px;
  }
  .filter-title { font-size: 16px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
  .filter-group { margin-bottom: 20px; }
  .filter-group h4 { font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; font-weight: 600; }
  .filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    cursor: pointer;
    font-size: 14px;
    color: var(--text);
    transition: color .2s;
  }
  .filter-option:hover { color: var(--accent); }
  .filter-option input[type="checkbox"] { accent-color: var(--accent); width: 14px; height: 14px; }
  .price-range { width: 100%; accent-color: var(--accent); margin-top: 8px; }
  .price-display { font-size: 13px; color: var(--accent); margin-top: 6px; }

  /* ===== PRODUCT DETAIL ===== */
  .product-detail-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 40px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .product-gallery {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 120px;
    min-height: 350px;
  }
  .product-detail-info {}
  .product-detail-brand { font-size: 13px; color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px; }
  .product-detail-name { font-size: 28px; font-weight: 800; margin-bottom: 12px; line-height: 1.3; }
  .product-detail-rating { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .product-detail-price { font-size: 38px; font-weight: 900; color: var(--accent3); margin-bottom: 8px; }
  .product-detail-old { font-size: 18px; color: var(--muted); text-decoration: line-through; margin-bottom: 20px; }
  .specs-table {
    background: var(--bg3);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
  }
  .specs-row {
    display: flex;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
  }
  .specs-row:last-child { border: none; }
  .specs-key { width: 140px; color: var(--muted); flex-shrink: 0; }
  .specs-val { color: var(--text); font-weight: 600; }
  .detail-btns { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ===== CART ===== */
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    padding: 40px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .cart-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
    transition: all .2s;
  }
  .cart-item:hover { border-color: var(--border); }
  .cart-item-img {
    width: 80px; height: 80px;
    background: var(--bg3);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    flex-shrink: 0;
  }
  .cart-item-info { flex: 1; }
  .cart-item-name { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
  .cart-item-brand { font-size: 12px; color: var(--accent); }
  .qty-control {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px 8px;
  }
  .qty-btn {
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 4px;
    transition: all .2s;
  }
  .qty-btn:hover { background: var(--border); color: var(--accent); }
  .qty-num { font-weight: 700; font-size: 15px; min-width: 24px; text-align: center; }
  .cart-item-price { font-size: 20px; font-weight: 900; color: var(--accent3); text-align: left; }

  .cart-summary {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    height: fit-content;
    position: sticky;
    top: 80px;
  }
  .summary-title { font-size: 18px; font-weight: 700; margin-bottom: 20px; }
  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    margin-bottom: 12px;
    color: var(--muted);
  }
  .summary-row.total {
    color: var(--text);
    font-size: 18px;
    font-weight: 800;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    margin-top: 12px;
  }
  .summary-row span:last-child { color: var(--accent3); font-weight: 700; }
  .coupon-input {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }
  .coupon-input input {
    flex: 1;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    font-size: 13px;
  }
  .coupon-input input:focus { outline: none; border-color: var(--accent); }

  /* ===== CHECKOUT ===== */
  .checkout-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    padding: 40px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .form-section {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
  }
  .form-section-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-group { margin-bottom: 14px; }
  .form-group.full { grid-column: 1/-1; }
  .form-label { display: block; font-size: 13px; color: var(--muted); margin-bottom: 6px; font-weight: 600; }
  .form-input {
    width: 100%;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    font-size: 14px;
    transition: all .2s;
  }
  .form-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,212,255,0.1); }
  .payment-options { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
  .pay-opt {
    background: var(--bg3);
    border: 2px solid var(--border);
    border-radius: 10px;
    padding: 14px;
    text-align: center;
    cursor: pointer;
    font-size: 22px;
    transition: all .2s;
  }
  .pay-opt:hover, .pay-opt.selected {
    border-color: var(--accent);
    background: rgba(0,212,255,0.08);
  }
  .pay-opt small { display: block; font-size: 11px; color: var(--muted); margin-top: 4px; }

  /* ===== PC BUILDER ===== */
  .builder-section { padding: 40px; }
  .builder-title { font-size: 28px; font-weight: 900; margin-bottom: 8px; }
  .builder-subtitle { color: var(--muted); margin-bottom: 30px; }
  .builder-grid { display: grid; grid-template-columns: 1fr 320px; gap: 24px; }
  .component-slots { }
  .component-slot {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: all .2s;
    cursor: pointer;
  }
  .component-slot:hover { border-color: var(--accent); }
  .slot-icon {
    width: 48px; height: 48px;
    background: var(--bg3);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }
  .slot-info { flex: 1; }
  .slot-type { font-size: 11px; color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .slot-name { font-size: 15px; font-weight: 600; margin-top: 2px; }
  .slot-detail { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .slot-price { font-size: 16px; font-weight: 800; color: var(--accent3); }
  .slot-action {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.3);
    color: var(--accent);
    cursor: pointer;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all .2s;
  }
  .slot-action:hover { background: var(--accent); color: var(--bg); }
  .slot-action.remove { border-color: rgba(239,68,68,0.3); color: var(--red); background: rgba(239,68,68,0.1); }
  .slot-action.remove:hover { background: var(--red); color: white; }

  .builder-summary {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    height: fit-content;
    position: sticky;
    top: 80px;
  }
  .compatibility-check {
    background: var(--bg3);
    border-radius: 10px;
    padding: 14px;
    margin-bottom: 16px;
  }
  .compat-row { display: flex; align-items: center; gap: 8px; font-size: 13px; margin-bottom: 8px; }
  .compat-row:last-child { margin: 0; }
  .dot-green { width: 8px; height: 8px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
  .dot-orange { width: 8px; height: 8px; border-radius: 50%; background: var(--accent3); flex-shrink: 0; }
  .dot-gray { width: 8px; height: 8px; border-radius: 50%; background: var(--muted); flex-shrink: 0; }

  /* ===== AUTH ===== */
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .auth-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(124,58,237,0.15) 0%, transparent 70%);
  }
  .auth-card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    width: 100%;
    max-width: 420px;
  }
  .auth-logo { text-align: center; font-family: 'Rajdhani', sans-serif; font-size: 32px; font-weight: 700; color: var(--accent); margin-bottom: 8px; letter-spacing: 3px; }
  .auth-logo span { color: var(--accent2); }
  .auth-subtitle { text-align: center; color: var(--muted); font-size: 14px; margin-bottom: 28px; }
  .auth-tabs {
    display: flex;
    background: var(--bg3);
